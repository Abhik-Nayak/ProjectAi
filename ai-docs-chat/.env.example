# API
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# File Upload
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads

# OpenAI
OPENAI_API_KEY=your_openai_api_key
